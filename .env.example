# ── Copy to `.env` on the SERVER and fill in. NEVER commit .env. ──
# Database (SQLite file next to the app). Absolute path on the server is fine too.
DATABASE_URL="file:./prisma/prod.db"

# Session signing secret — set to a long random string (e.g. `openssl rand -hex 32`).
AUTH_SECRET="change-me-to-a-long-random-string"

# First admin (used only by the seed script on first setup).
SEED_ADMIN_EMAIL="admin@skazkamuseum.ru"
SEED_ADMIN_PASSWORD="change-me-strong-password"

# GitHub access for pull.bat/push.bat (fine-grained PAT, repo SkazkaMuseum,
# permission "Contents: Read and write"). Leave blank if this PC's git
# already has its own GitHub credentials (e.g. Pavel's machine).
GITHUB_TOKEN=""

# Git identity for commits made from this PC (used by push.bat if git has none).
GIT_USER_NAME="Skazka CEO"
GIT_USER_EMAIL="ceo@skazkamuseum.ru"

# ── Integrations (leave blank until ready; app runs fine without them) ──
# YooKassa (payments)
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""

# Transactional email via Yandex 360 SMTP (domain mailbox). The password is an
# APP password for the mailbox (id.yandex.ru → Безопасность → Пароли приложений),
# never the normal mailbox password. From-address = the mailbox itself.
YANDEX_SMTP_PASSWORD=""
# YANDEX_SMTP_USER="spb@skazkamuseum.ru"

# Telegram bot (new-lead notifications)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Public origin (used in payment return URLs)
NEXT_PUBLIC_SITE_URL="https://skazkamuseum.ru"
