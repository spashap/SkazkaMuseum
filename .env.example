# ── Copy to `.env` on the SERVER and fill in. NEVER commit .env. ──
# Database (SQLite file next to the app). Absolute path on the server is fine too.
DATABASE_URL="file:./prisma/prod.db"

# Session signing secret — set to a long random string (e.g. `openssl rand -hex 32`).
AUTH_SECRET="change-me-to-a-long-random-string"

# First admin (used only by the seed script on first setup).
SEED_ADMIN_EMAIL="admin@skazkamuseum.ru"
SEED_ADMIN_PASSWORD="change-me-strong-password"

# ── Integrations (leave blank until ready; app runs fine without them) ──
# YooKassa (payments)
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""

# UniSender GO v2 (email)
UNISENDER_GO_API_KEY=""

# Telegram bot (new-lead notifications)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Public origin (used in payment return URLs)
NEXT_PUBLIC_SITE_URL="https://skazkamuseum.ru"
